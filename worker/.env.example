PORT=4567

# Must match WORKER_API_TOKEN in the web app.
WORKER_API_TOKEN=replace-with-long-random-secret

# HTTPS origin of the deployed web app. Used when the web request does not include callbackUrl.
WEB_CALLBACK_BASE=https://your-domain.com

# Path to the BlockMesh CLI executable on the worker machine.
BLOCKMESH_EXE=C:\BlockMeshCLI\blockmesh.exe

# Optional test/debug only. Leave empty in production.
BLOCKMESH_SCRIPT=

# Worker runtime workspace. Cookie files are written here temporarily and deleted after each job.
WORKER_WORKSPACE=C:\BlockMeshWorker\.work

# Keep low until you have measured endpoint rate limits.
WORKER_CONCURRENCY=1
WORKER_STATUS_INTERVAL_MS=10000

# Set to 1 only while debugging. Successful job folders are otherwise deleted.
WORKER_KEEP_WORKSPACES=0
