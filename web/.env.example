NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase auth/database. Run web/supabase/schema.sql before enabling these.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Required in production. Used to encrypt job_inputs.account_text at rest.
JOB_INPUT_ENCRYPTION_KEY=replace-with-long-random-secret

# Optional local worker bridge for development only. Do not enable this on Vercel.
BLOCKMESH_LOCAL_WORKER=0
BLOCKMESH_CLI_DIR=C:\BlockMeshCLI
BLOCKMESH_EXE=C:\BlockMeshCLI\blockmesh.exe

# Admin seed script. Set ADMIN_PASSWORD locally before running npm run seed:admin.
ADMIN_EMAIL=admin@blockmesh.local
ADMIN_PASSWORD=

# External worker backend. The web app dispatches jobs server-side to this worker.
WORKER_API_BASE=https://worker.your-domain.com
WORKER_API_TOKEN=replace-with-worker-token

# Worker callbacks use NEXT_PUBLIC_SITE_URL:
# POST /api/worker/jobs/:jobId/status
# POST /api/worker/jobs/:jobId/complete

# Payment mode:
# placeholder = accepts valid-looking voucher URLs for UI testing only.
# TrueMoney live redemption is intentionally disabled until after deploy.
PAYMENT_PROVIDER_MODE=placeholder

# Keep this 0 in production. Set to 1 only for local/demo UI testing.
ALLOW_PLACEHOLDER_TOPUP=0

# Queue safety guard. Users cannot confirm more queued/running/retrying jobs than this.
MAX_ACTIVE_JOBS_PER_USER=2

# Future TrueMoney provider settings. Leave disabled until the provider/API is ready.
TRUEMONEY_API_BASE=
TRUEMONEY_API_TOKEN=

# Public endpoint to register after deploying your domain:
# https://your-domain.com/api/payments/truemoney/webhook
TRUEMONEY_WEBHOOK_SECRET=replace-with-webhook-secret
